<mujoco model="car_arm">
  <compiler angle="degree"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.5" armature="0.1"/>
    <geom type="capsule" rgba="0.7 0.7 0.7 1"/>
    <motor gear="14.7" ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <worldbody>
    <body name="base" pos="0 0 0">
      <geom type="box" size="0.05 0.05 0.0425" rgba="0.3 0.3 0.3 1"/>

      <!-- 관절1: 수평 회전 (베이스 위) -->
      <body name="link1" pos="0 0 0.085">
        <joint name="joint1_yaw" type="hinge" axis="0 0 1" range="-120 120"/>
        <geom fromto="0 0 0 0 0 0.037" size="0.018"/>

        <!-- 관절2: 수직 회전 (어깨) -->
        <body name="link2" pos="0 0 0.037">
          <joint name="joint2_shoulder" type="hinge" axis="0 1 0" range="-90 90"/>
          <geom fromto="0 0 0 0 0 0.130" size="0.016"/>

          <!-- 관절3: 수직 회전 (팔꿈치1) - 0~180도 -->
          <body name="link3" pos="0.025 0 0.130">
            <joint name="joint3_elbow1" type="hinge" axis="0 1 0" range="0 180"/>
            <geom fromto="0 0 0 0 0 0.130" size="0.015"/>

            <!-- 관절4: 수직 회전 (팔꿈치2) -->
            <body name="link4" pos="0 0 0.130">
              <joint name="joint4_elbow2" type="hinge" axis="0 1 0" range="-120 120"/>
              <geom fromto="0 0 0 0 0 0.077" size="0.013"/>

              <!-- 관절5: 수평 회전 (손목) -->
              <body name="link5" pos="0 0 0.077">
                <joint name="joint5_wrist" type="hinge" axis="0 0 1" range="-120 120"/>
                <geom fromto="0 0 0 0 0 0.015" size="0.011"/>
                <site name="end_effector" pos="0 0 0.015" size="0.012" rgba="0 1 0 1"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- 목표 위치 마커 -->
    <body name="target" pos="0.25 0 0.20">
      <geom type="sphere" size="0.015" rgba="1 0 0 0.7" contype="0" conaffinity="0"/>
      <site name="target_site" size="0.015"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="act1" joint="joint1_yaw"/>
    <motor name="act2" joint="joint2_shoulder"/>
    <motor name="act3" joint="joint3_elbow1"/>
    <motor name="act4" joint="joint4_elbow2"/>
    <motor name="act5" joint="joint5_wrist"/>
  </actuator>

</mujoco>
